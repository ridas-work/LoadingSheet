# Local VPS (production) — auth required:
# MONGODB_URI=mongodb://USER:PASSWORD@127.0.0.1:27017/loadingsheet?authSource=loadingsheet
# Atlas (optional):
# Fleet app (vehicle plates + driver names for dispatch trip dropdowns):
# FLEET_MONGODB_URI=mongodb://USER:PASSWORD@127.0.0.1:27017/fleetmonitor?authSource=fleetmonitor
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/loadingsheet?retryWrites=true&w=majority
NEXTAUTH_SECRET=generate-a-long-random-string-here
NEXTAUTH_URL=http://localhost:3000
